# این فایل رو کپی کن به .env (یا مستقیم توی تنظیمات Render/سرور بذارشون)
# هیچ‌وقت مقادیر واقعی رو توی گیت‌هاب پابلیک نکن.

# توکنی که از @BotFather می‌گیری
BOT_TOKEN=

# رشته‌ی اتصال Postgres که از Neon (neon.tech) کپی می‌کنی
# شکلش یه چیزی شبیه اینه:
# postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# پورتی که Render خودش ست می‌کنه (لازم نیست دستی پر کنی، خودش می‌ده)
PORT=8080
